        "diagram",
        "pdf"
      ]
    },
    "summary": {
      "type": "textarea",
      "display_name": "Summary"
    },
    "whatItProves": {
      "type": "textarea",
      "display_name": "What It Proves"
    },
    "businessOutcome": {
